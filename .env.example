# ===== LINE Messaging API =====
# LINE Developers Console の Messaging API チャネル設定から取得
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# 毎朝8時の自動通知を送る対象のLINEユーザーID（自分のユーザーID）
# Botに「ID教えて」などと話しかけて、Webhookログから取得するか、
# LINE Developers Consoleの「Your user ID」を使用
LINE_USER_ID=your_line_user_id_here

# ===== Anthropic Claude API =====
# https://console.anthropic.com/ から取得
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===== Google API (Calendar / Sheets / Drive) =====
# Google Cloud Console で OAuth 2.0 クライアントを作成して取得
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here

# 使用するGoogleカレンダーID（メインカレンダーなら 'primary' でOK）
GOOGLE_CALENDAR_ID=primary

# 請求書テンプレートのGoogle SheetsファイルID
# Sheets URL: https://docs.google.com/spreadsheets/d/【ここがID】/edit
INVOICE_TEMPLATE_SHEET_ID=your_invoice_template_sheet_id_here

# 請求書PDFを保存するGoogle DriveフォルダID（任意・未指定ならマイドライブ直下）
INVOICE_DRIVE_FOLDER_ID=

# タスク管理用Google SheetsファイルID
# A列:タスク名 / B列:優先度(高・中・低) / C列:期限(YYYY-MM-DD) / D列:状態(未完了・完了)
TASKS_SHEET_ID=your_tasks_sheet_id_here

# ===== Instagram Graph API =====
# Meta for Developers から取得（Facebook Page と連携した Instagram ビジネスアカウントが必要）
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id_here

# ===== Threads 自動投稿モジュール =====
# scripts/setup-knowledge-sheet.js / scripts/setup-posts-log-sheet.js を
# 実行して取得したシートIDを設定
KNOWLEDGE_SHEET_ID=
POSTS_LOG_SHEET_ID=

# Threads API（後で取得 — Phase 4実装済み、フォールバックモードで動作可）
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# 動作設定（デフォルト値で運用可）
PROPOSAL_TIMES=07:00,11:30,16:30      # 投稿案を生成・送信する時刻
POST_TIMES=09:00,12:00,18:00          # 投稿実行時刻
PROPOSAL_COUNT=3                       # 1回あたりの提案数
POST_MAX_LENGTH=100                    # 投稿最大文字数
HIT_THRESHOLD=3.0                      # ヒット判定エンゲ率（%）
THREADS_FALLBACK_MODE=true             # API取得前はコピペモード

# ===== サーバー設定 =====
PORT=3000
